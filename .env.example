# Runtime
PORT=3000
NODE_ENV=production
ADMIN_TOKEN=your_secure_admin_token
JWT_SECRET=your_secure_jwt_secret

# External APIs
FORTNITE_API_KEY=your_fortnite_api_key

# Database (Postgres)
DATABASE_URL=postgresql://user:password@host:port/dbname

# Cache (Redis)
REDIS_URL=redis://host:port

# Cloudflare R2
R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_BUCKET_NAME=pathgen-assets
R2_PUBLIC_DOMAIN=https://your_public_domain.r2.dev  # Get this from Cloudflare R2 bucket settings

# Firebase Client Configuration (Get this from project settings > general > our apps)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=pathgen-api
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Firebase
# For Railway: Copy the JSON from your Firebase service account key file
FIREBASE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"pathgen-prod",...}'
